<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>AzureAISearchTutorialCompanion</AssemblyName>
    <RootNamespace>AzureAISearchTutorialCompanion</RootNamespace>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="AzureAISearchTutorialCompanion.TestHarness" />
    <InternalsVisibleTo Include="TestConsole" />
    <Compile Remove="TestConsole\**" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="icon.png" />
  </ItemGroup>

  <ItemGroup>
    <!-- OutSystems ODC External Libraries SDK -->
    <PackageReference Include="OutSystems.ExternalLibraries.SDK" Version="1.5.0" />
    <!-- PDF text extraction (MIT license, no native dependencies) -->
    <PackageReference Include="PdfPig" Version="0.1.14" />
  </ItemGroup>

</Project>
